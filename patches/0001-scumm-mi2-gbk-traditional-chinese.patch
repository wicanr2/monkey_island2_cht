diff --git a/engines/scumm/charset.cpp b/engines/scumm/charset.cpp
index 81c14ae2..d034c63e 100644
--- a/engines/scumm/charset.cpp
+++ b/engines/scumm/charset.cpp
@@ -127,6 +127,9 @@ void ScummEngine::loadCJKFont() {
 				fontFile = "chinese_gb16x12.fnt";
 				numChar = 8178;
 			}
+			// CHT(MI2 繁體): 用 GBK 全 range 字型(含繁體字), numChar 擴到 23940
+			if (_game.id == GID_MONKEY2)
+				numChar = 23940;
 			break;
 		default:
 			break;
@@ -301,7 +304,14 @@ byte *ScummEngine::get2byteCharPtr(int idx) {
 			return _2byteFontPtr + base;
 		}
 	case Common::ZH_CHN:
-		idx = ((idx % 256) - 0xa1)* 94  + ((idx / 256) - 0xa1);
+		// CHT(MI2 繁體): GBK 線性 index。操作元對應關係與上方 GB2312 版一致
+		// (×190 的操作元 = idx%256；帶 0x40/0x41 調整的 = idx/256)，字型 generator 同構。
+		if (_game.id == GID_MONKEY2) {
+			int t = idx / 256;
+			idx = ((idx % 256) - 0x81) * 190 + (t < 0x7f ? t - 0x40 : t - 0x41);
+		} else {
+			idx = ((idx % 256) - 0xa1)* 94  + ((idx / 256) - 0xa1);
+		}
 		break;
 	default:
 		idx = 0;
